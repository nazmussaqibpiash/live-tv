# ============================================================
#  Live TV — environment template
#  Copy this to `.env` and fill in real values. `.env` is git-ignored.
# ============================================================

# GitHub PAT — scopes: repo, workflow, admin:repo_hook
GITHUB_TOKEN=

# Cloudflare API token (Workers + KV + D1 + DNS edit) and account id
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare resource IDs (created via wrangler)
CLOUDFLARE_KV_CATALOG_ID=
CLOUDFLARE_D1_DATABASE_ID=

# Public URLs (custom domains)
PUBLIC_SITE_URL=
PUBLIC_WORKER_URL=
